{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AIProviders": {
    "DefaultProvider": "Groq",
    "FallbackOrder": [ "Groq", "OpenAI" ],
    "OpenAI": {
      "Enabled": true,
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": "",
      "DefaultModel": "gpt-4o",
      "Models": [ "gpt-4o", "gpt-4o-mini" ],
      "Temperature": 0.2,
      "MaxTokens": 4096,
      "TimeoutSeconds": 60
    },
    "Groq": {
      "Enabled": true,
      "BaseUrl": "https://api.groq.com/openai/v1",
      "ApiKey": "",
      "DefaultModel": "llama-3.3-70b-versatile",
      "Models": [ "llama-3.3-70b-versatile", "llama-3.1-8b-instant" ],
      "Temperature": 0.2,
      "MaxTokens": 4096,
      "TimeoutSeconds": 30
    }
  },
  "Prompting": {
    "ResourceRoot": "resources",
    "PromptPackVersion": "2026.06",
    "CacheTtlSeconds": 300,
    "WatchForChanges": true
  },
  "Resilience": {
    "RetryCount": 3,
    "BaseDelayMs": 400,
    "UseJitter": true,
    "CircuitBreaker": {
      "FailureThreshold": 0.5,
      "BreakSeconds": 30
    }
  }
}
