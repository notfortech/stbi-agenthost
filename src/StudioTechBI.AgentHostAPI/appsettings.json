{
  "AllowedHosts": "*",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "Swagger": {
    "Enabled": true
  },

  "Agent": {
    "Provider": "OpenAI",
    "Model": "gpt-4o",
    "SaveBlueprints": true,
    "BlueprintFolder": "GeneratedBlueprints"
  },

  "AIProviders": {
    "DefaultProvider": "OpenAI",
    "FallbackOrder": [ "OpenAI" ],
    "Claude": {
      "Enabled": false,
      "BaseUrl": "https://api.anthropic.com",
      "ApiKey": "",
      "DefaultModel": "claude-sonnet-4-6",
      "AnthropicVersion": "2023-06-01",
      "Models": [ "claude-sonnet-4-6", "claude-haiku-4-5-20251001" ],
      "Temperature": 0.2,
      "MaxTokens": 16000,
      "TimeoutSeconds": 240
    },
    "OpenAI": {
      "Enabled": true,
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": "",
      "DefaultModel": "gpt-4o",
      "Models": [ "gpt-4o", "gpt-4o-mini" ],
      "Temperature": 0.2,
      "MaxTokens": 16000,
      "TimeoutSeconds": 240
    },
    "Groq": {
      "Enabled": false,
      "BaseUrl": "https://api.groq.com/openai/v1",
      "ApiKey": "",
      "DefaultModel": "llama-3.3-70b-versatile",
      "Models": [ "llama-3.3-70b-versatile", "llama-3.1-8b-instant" ],
      "Temperature": 0.2,
      "MaxTokens": 32000,
      "TimeoutSeconds": 240
    }
  },

  "Prompting": {
    "ResourceRoot": "resources",
    "PromptPackVersion": "2026.06",
    "CacheTtlSeconds": 300,
    "WatchForChanges": true
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Database": {
    "Provider": "SqlServer",
    "ConnectionString": ""
  },

  "SubscriptionDefaults": {
    "CreditsConsumedPerRequest": 1,
    "DefaultPlanName": "Trial",
    "FallbackTenantId": "demo-tenant",
    "AutoRegisterNewTenants": true
  },

  "AgentLimits": {
    "Trial": {
      "CreditsPerCycle": 10,
      "ResetFrequency": "Monthly",
      "IsUnlimited": false,
      "MaxRequestsPerMinute": 5,
      "MaxConcurrentRequests": 1
    },
    "Starter": {
      "CreditsPerCycle": 100,
      "ResetFrequency": "Monthly",
      "IsUnlimited": false,
      "MaxRequestsPerMinute": 10,
      "MaxConcurrentRequests": 2
    },
    "Professional": {
      "CreditsPerCycle": 500,
      "ResetFrequency": "Monthly",
      "IsUnlimited": false,
      "MaxRequestsPerMinute": 30,
      "MaxConcurrentRequests": 5
    },
    "Enterprise": {
      "CreditsPerCycle": 0,
      "ResetFrequency": "Monthly",
      "IsUnlimited": true,
      "MaxRequestsPerMinute": 100,
      "MaxConcurrentRequests": 20
    }
  },

  "Auth": {
    "ApiKey": ""
  },

  "AdminSettings": {
    "EnableDetailedUsageLogging": true
  },

  "Cors": {
    "AllowedOrigins": [
      "https://thankful-rock-087464e00.4.azurestaticapps.net"
    ]
  },

  "Resilience": {
    "RetryCount": 3,
    "BaseDelayMs": 400,
    "UseJitter": true,
    "CircuitBreaker": {
      "FailureThreshold": 0.5,
      "BreakSeconds": 30
    }
  }
}
